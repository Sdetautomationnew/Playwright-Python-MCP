# Copy this file to .env before running the framework.
# Load order: environments/base.env, then .env, then the selected environment file, then .env.local, then the environment-specific local file.
ENV=staging

JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
TESTRAIL_BASE_URL=
TESTRAIL_API_KEY=
TESTRAIL_RUN_ID=
SLACK_WEBHOOK_URL=

# =========================================================
# Optional: Email test reports
# =========================================================
# When enabled, the framework sends an email at the end of the pytest run
# with a zip attachment containing:
# - reports/report.html
# - reports/junit-report.xml
# - reports/logs/
#
# NOTE: Keep credentials out of git. This file is a template only.
EMAIL_ENABLED=false
EMAIL_TO=
EMAIL_FROM=

# SMTP server (example: Gmail/SMTP relay/etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_SUBJECT_PREFIX=Playwright Tests

# Optional local overrides. Leave these commented unless you want to override the selected environment file.
# BASE_URL=https://www.saucedemo.com
# API_URL=https://fakestoreapi.com
# DEFAULT_ACTION_TIMEOUT_MS=10000
# DEFAULT_NAVIGATION_TIMEOUT_MS=30000
# CUSTOM_VIEWPORT_WIDTH=390
# CUSTOM_VIEWPORT_HEIGHT=844
# CUSTOM_DEVICE_SCALE_FACTOR=3
# MCP_ENABLED=true
# MCP_SERVER_URL=ws://localhost:8080
