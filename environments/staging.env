# Staging environment overrides
ENV=staging
BASE_URL=https://www.saucedemo.com
API_URL=https://fakestoreapi.com
BROWSER=firefox
DEFAULT_ACTION_TIMEOUT_MS=10000
DEFAULT_NAVIGATION_TIMEOUT_MS=30000
MCP_ENABLED=true
MCP_SERVER_URL=ws://127.0.0.1:8080

# =========================================================
# Optional: Email test reports
# =========================================================
EMAIL_ENABLED=false
EMAIL_TO=
EMAIL_FROM=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_SUBJECT_PREFIX=Playwright Tests
