# Base environment configuration
# Shared defaults loaded for every run
BASE_URL=https://www.saucedemo.com
API_URL=https://fakestoreapi.com
BROWSER=chromium
HEADLESS=false
TIMEOUT=30000
DEFAULT_ACTION_TIMEOUT_MS=10000
DEFAULT_NAVIGATION_TIMEOUT_MS=30000
CUSTOM_VIEWPORT_WIDTH=390
CUSTOM_VIEWPORT_HEIGHT=844
CUSTOM_DEVICE_SCALE_FACTOR=3
MCP_ENABLED=false
MCP_SERVER_URL=ws://localhost:8080

# =========================================================
# Optional: Email test reports
# =========================================================
EMAIL_ENABLED=false
EMAIL_TO=
EMAIL_FROM=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_SUBJECT_PREFIX=Playwright Tests
